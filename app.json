{
  "expo": {
    "name": "AkwaHome",
    "slug": "AkwaHomeMobile",
    "scheme": "akwahomemobile",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jeanbrice270.akwahomemobile",
      "buildNumber": "22",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take profile, property, and vehicle photos.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to select photos to upload.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio messages if you choose this feature.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jeanbrice270.AkwaHomeMobile",
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e67e22",
          "sounds": []
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "12d9662b-4b81-4be0-a4f6-314008b89905"
      }
    }
  }
}
